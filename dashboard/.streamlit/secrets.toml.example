# .streamlit/secrets.toml.example
#
# Copy this file to dashboard/.streamlit/secrets.toml and fill in your values.
# The dashboard will auto-populate the sidebar with these credentials.
# NEVER commit secrets.toml — it is listed in .gitignore.
#
# Usage:
#   cp dashboard/.streamlit/secrets.toml.example dashboard/.streamlit/secrets.toml
#   streamlit run dashboard/app.py

[mysql]
host     = "localhost"
port     = 3306
user     = "root"
password = "your_password_here"
database = "public_library"
